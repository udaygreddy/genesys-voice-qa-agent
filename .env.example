# ── Genesys Cloud ────────────────────────────────────────────────────────────
# Region key (see genesys_auth.py REGION_DOMAINS for all options)
GENESYS_REGION=us-east-1

# OAuth2 Client Credentials app (Admin > OAuth > Add Client > Client Credentials)
# Required scopes: notifications, conversations:readonly
GENESYS_CLIENT_ID=your-client-id-here
GENESYS_CLIENT_SECRET=your-client-secret-here

# ── LLM backend ──────────────────────────────────────────────────────────────
# "azure" (default) or "gateway" (InHouseGatewayCompletionClient)
LLM_BACKEND=azure

# Azure OpenAI — used when LLM_BACKEND=azure
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# In-house gateway — used when LLM_BACKEND=gateway
# Replace in_house_gateway_completion.py with your gateway's contract if needed
# AI_GATEWAY_BASE_URL=https://your-ai-gateway.internal
# AI_GATEWAY_API_KEY=optional-key
# AI_GATEWAY_MODEL=gpt-4o

# ── Notifications ─────────────────────────────────────────────────────────────
# Priority: Slack → Webhook → stdout logging

# Slack Bot (recommended)
# 1. Create a Slack App at https://api.slack.com/apps
# 2. Add Bot Token Scopes: chat:write  (and chat:write.public for public channels)
# 3. Install the app to your workspace and copy the Bot User OAuth Token (xoxb-...)
# 4. Invite the bot to the target channel:  /invite @your-bot-name
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_CHANNEL=#call-quality          # channel name, ID (C...), or user ID (U...) for DMs

# Generic webhook fallback (used only when Slack vars are not set)
# POST JSON payload to Teams, PagerDuty, your own API, etc.
NOTIFICATION_WEBHOOK_URL=

# ── Tuning ───────────────────────────────────────────────────────────────────
# Trigger mid-call LLM analysis every N utterances (default 20)
ANALYSIS_UTTERANCE_WINDOW=20

# Logging verbosity: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
